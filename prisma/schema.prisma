// 세움 정산 OS - 데이터 모델 (PostgreSQL / Supabase)
// 계약(수기/전자) → 회차별 납입(계약금/중도금/잔금) → 수납 체크 → 매출/부가세 집계
//   source:  MANUAL | ELECTRONIC              (수기 | 전자)
//   taxType: TAXABLE | ZERO_RATED | EXEMPT    (과세 | 영세율 | 면세)
//   status:  ACTIVE | COMPLETED | CANCELED    (진행중 | 완납 | 해지)
//   kind:    DOWN_PAYMENT | INTERIM | BALANCE (계약금 | 중도금 | 잔금)
generator client {
  provider = "prisma-client-js"
  // Netlify(AWS Lambda) 서버리스 런타임용 쿼리 엔진 바이너리 포함
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contract {
  id           String   @id @default(cuid())
  contractNo   String   @unique // 계약번호 (예: C-2026-0001)
  title        String // 계약명 / 프로젝트명
  clientName   String // 거래처(고객)명
  clientBizNo  String? // 사업자등록번호
  source       String   @default("ELECTRONIC") // 수기 / 전자
  taxType      String   @default("TAXABLE") // 과세유형
  status       String   @default("ACTIVE") // 진행 상태
  totalAmount  Int // 총 계약금액 (부가세 포함, 원 단위)
  contractDate DateTime // 계약일
  memo         String?
  documentName String? // 첨부 계약서 원본 파일명
  documentId   String? // 첨부 파일(Document) id
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  installments Installment[]
  expenses     Expense[]
  document     Document?     @relation(fields: [documentId], references: [id], onDelete: SetNull)
}

model Installment {
  id             String    @id @default(cuid())
  contractId     String
  contract       Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  kind           String // DOWN_PAYMENT | INTERIM | BALANCE
  label          String // 표시명 (예: "중도금 1차")
  seq            Int       @default(1) // 회차 순서
  plannedAmount  Int // 청구(예정) 금액
  dueDate        DateTime? // 납입 예정일
  received       Boolean   @default(false) // 수납 완료 체크
  receivedAmount Int       @default(0) // 실제 수납 금액
  receivedDate   DateTime? // 실제 수납일
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([contractId])
  @@index([receivedDate])
}

model Expense {
  id          String    @id @default(cuid())
  expenseDate DateTime // 지출일
  category    String // 비용 항목 (인건비/임차료/외주비/광고선전비 등)
  vendor      String? // 거래처
  description String?
  amount      Int // 지출 금액 (부가세 포함, 원 단위)
  taxType     String    @default("TAXABLE") // 매입 과세유형 (매입세액 공제 여부)
  contractId  String? // 특정 계약에 귀속되는 비용이면 연결
  contract    Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([expenseDate])
  @@index([contractId])
}

// 업로드된 계약서 파일(수기 스캔본/전자계약 PDF)을 DB에 저장.
// 서버리스(Netlify) 환경은 디스크 쓰기가 불가능하므로 바이트를 Postgres 에 보관한다.
model Document {
  id        String     @id @default(cuid())
  filename  String
  mimeType  String
  size      Int
  data      Bytes
  createdAt DateTime   @default(now())

  contracts Contract[]
}
